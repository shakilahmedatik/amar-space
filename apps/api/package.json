{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "test": "vitest --run",
    "test:unit": "vitest --run tests/unit",
    "test:properties": "vitest --run tests/properties",
    "test:integration": "vitest --run tests/integration",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1054.0",
    "@aws-sdk/s3-request-presigner": "^3.1054.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/swagger": "^9.7.0",
    "@logtape/fastify": "^2.1.1",
    "@logtape/logtape": "^2.1.1",
    "@repo/db": "workspace:*",
    "@repo/shared": "workspace:*",
    "@scalar/fastify-api-reference": "^1.57.5",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "better-auth": "1.6.11",
    "drizzle-orm": "0.45.2",
    "fastify": "5.8.5",
    "fastify-plugin": "5.0.1",
    "fastify-type-provider-zod": "6.1.0",
    "pngjs": "^7.0.0",
    "qrcode": "^1.5.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/adm-zip": "^0.5.8",
    "@types/archiver": "^6.0.3",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "22.15.30",
    "@types/pngjs": "^6.0.5",
    "@types/qrcode": "^1.5.5",
    "adm-zip": "^0.5.17",
    "fast-check": "4.8.0",
    "jsqr": "^1.4.0",
    "tsup": "^8.5.1",
    "tsx": "4.19.4",
    "typescript": "5.9.2",
    "vitest": "4.1.7"
  }
}
