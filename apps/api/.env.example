# =============================================================================
# AmarSpace API - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# These values override root-level .env variables of the same name.
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/amarspace # Full connection URL for Drizzle ORM

# --- Authentication (Better Auth) ---
AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars # Secret key for signing sessions (min 32 characters)
AUTH_BASE_URL=http://localhost:3001 # Base URL of the auth server

# --- Database Connection Pool ---
DB_POOL_SIZE=10                 # Maximum connections per serverless instance (1-20)
DB_IDLE_TIMEOUT=30000           # Idle connection timeout in ms (1000-60000)
DB_CONNECTION_TIMEOUT=10000     # Connection attempt timeout in ms (1000-10000)

# --- Application ---
NODE_ENV=development            # Environment: development | production | test
