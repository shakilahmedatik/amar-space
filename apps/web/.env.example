# =============================================================================
# AmarSpace Web (Next.js) - Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in the values.
# These values override root-level .env variables of the same name.
# =============================================================================

# --- Public (exposed to the browser via NEXT_PUBLIC_ prefix) ---
NEXT_PUBLIC_API_URL=http://localhost:3001 # URL of the backend API

# --- Server-side only ---
AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars # Secret key for session verification (min 32 characters)
AUTH_BASE_URL=http://localhost:3001 # Base URL of the auth server

# --- Application ---
NODE_ENV=development            # Environment: development | production | test
