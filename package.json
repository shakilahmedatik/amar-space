{
	"name": "amar-space",
	"version": "1.0.0",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "NODE_OPTIONS='--max-old-space-size=4096' next dev --port 3000",
		"build": "next build",
		"start": "next start",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check --write .",
		"check-types": "next typegen && tsc --noEmit",
		"test": "vitest --run",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:reset": "tsx --env-file=.env lib/db/reset.ts",
		"db:seed": "tsx --env-file=.env lib/db/seed.ts"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1054.0",
		"@radix-ui/react-alert-dialog": "^1.1.15",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-label": "^2.1.8",
		"@radix-ui/react-radio-group": "^1.3.8",
		"@radix-ui/react-slot": "^1.2.4",
		"@tailwindcss/postcss": "^4.3.0",
		"@tanstack/react-query": "^5.100.14",
		"archiver": "^8.0.0",
		"better-auth": "1.6.11",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "0.45.2",
		"lucide-react": "^1.16.0",
		"next": "16.2.9",
		"pngjs": "^7.0.0",
		"postcss": "^8.5.15",
		"postgres": "3.4.5",
		"qrcode": "^1.5.4",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^4.3.0",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.8.3",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/archiver": "^8.0.0",
		"@types/node": "^22.15.3",
		"@types/pngjs": "^6.0.5",
		"@types/qrcode": "^1.5.6",
		"@types/react": "19.2.2",
		"@types/react-dom": "19.2.2",
		"drizzle-kit": "0.31.10",
		"fast-check": "4.8.0",
		"jsdom": "^29.1.1",
		"tsx": "^4.22.4",
		"typescript": "5.9.2",
		"vitest": "4.1.7"
	}
}
